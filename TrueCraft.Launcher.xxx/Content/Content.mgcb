
#----------------------------- Global Properties ----------------------------#

/outputDir:bin/$(Platform)
/intermediateDir:obj/$(Platform)
/platform:DesktopGL
/config:
/profile:Reach
/compress:False

#-------------------------------- References --------------------------------#

/reference:..\..\GeonBit.UI.DataTypes\bin\Debug\net6.0\GeonBit.UI.DataTypes.dll

#---------------------------------- Content ---------------------------------#

#begin background.png
