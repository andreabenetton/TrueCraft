{
  "Configuration": {
    "motd": "Welcome to TrueCraft!",
    "bind-port": 25565,
    "bind-endpoint": "0.0.0.0",
    "save-interval": 30,
    "Singleplayer": false,
    "query-enabled": true,
    "query-port": 25566,
    "enable-lighting": true,
    "enable-event-loading": true,
    "disable-events": []
  },
  "debug": {
    "deleteWorldOnStartup": false,
    "deletePlayersOnStartup": false
  },
  "profiler": {
    "buckets": "",
    "lag": false
  },
  "Access": {
    "blacklist": [],
    "whitelist": [],
    "ops": []
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Async",
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Process",
      "Serilog.Exceptions"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console",
              "Args": {
                "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
              }
            },
            {
              "Name": "File",
              "Args": {
                "path": "logs/TrueCraft..log",
                "rollingInterval": "Day",
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [Thread {ThreadId}] {SourceContext}: {Message:lj} {Properties:j}{NewLine}{Exception}"
              }
            }
          ]
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId",
      "WithEnvironmentName",
      "WithExceptionDetails"
    ]
  }
}
